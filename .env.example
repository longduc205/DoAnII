# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///scanner.db
# DATABASE_URL=mysql+pymysql://user:password@localhost/scanner_db

# Scanner Settings
CRAWL_MAX_DEPTH=3
CRAWL_MAX_PAGES=50
REQUEST_TIMEOUT=10
SCAN_DELAY=0.5

# AI Module
AI_MODEL_PATH=ai/models/classifier.pkl
AI_CONFIDENCE_THRESHOLD=0.7
